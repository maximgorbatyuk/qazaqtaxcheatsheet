---
interface Props {
  type: 'tip' | 'info' | 'warning' | 'error';
  title?: string;
}

const { type, title } = Astro.props;

const colorMap: Record<string, string> = {
  tip: 'var(--success)',
  info: 'var(--info)',
  warning: 'var(--warning)',
  error: 'var(--error)',
};

const color = colorMap[type];
---

<aside class:list={['callout', `callout-${type}`]} role="note">
  {title && <p class="callout-title">{title}</p>}
  <div class="callout-content">
    <slot />
  </div>
</aside>

<style define:vars={{ color }}>
  .callout {
    width: 100%;
    padding: var(--space-4) var(--space-5);
    border: 1px solid var(--border-secondary);
    border-left: 4px solid var(--color);
    border-radius: var(--radius-lg);
    margin-bottom: var(--space-4);
  }

  .callout-tip {
    background: color-mix(in srgb, var(--success) 5%, var(--bg-secondary));
  }

  .callout-info {
    background: color-mix(in srgb, var(--info) 5%, var(--bg-secondary));
  }

  .callout-warning {
    background: color-mix(in srgb, var(--warning) 5%, var(--bg-secondary));
  }

  .callout-error {
    background: color-mix(in srgb, var(--error) 5%, var(--bg-secondary));
  }

  .callout-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
    color: var(--color);
    margin-bottom: var(--space-2);
  }

  .callout-content {
    font-size: 1rem;
    color: var(--fg-secondary);
    line-height: var(--line-height-body);
  }

  .callout-content :global(p) {
    margin-bottom: var(--space-2);
  }

  .callout-content :global(p:last-child) {
    margin-bottom: 0;
  }

  .callout-content :global(ul),
  .callout-content :global(ol) {
    padding-left: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .callout-content :global(ul) {
    list-style: disc;
  }

  .callout-content :global(ol) {
    list-style: decimal;
  }

  .callout-content :global(a) {
    color: var(--link);
  }

  .callout-content :global(strong) {
    color: var(--fg-primary);
    font-weight: 600;
  }
</style>
