---
import NextPageNav from './NextPageNav.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const currentPath = Astro.url.pathname;
---

<div class="content-page">
  <header class="content-header">
    <h1 class="content-title">{title}</h1>
    {description && <p class="content-description">{description}</p>}
  </header>

  <div class="content-body">
    <slot />
  </div>

  <NextPageNav currentPath={currentPath} />
</div>

<style>
  .content-page {
    max-width: var(--reading-width);
    margin: 0 auto;
    padding: var(--space-8) var(--space-5);
    min-height: calc(100vh - var(--nav-height));
  }

  .content-header {
    margin-bottom: var(--space-7);
  }

  .content-title {
    font-size: clamp(1.75rem, 1.4rem + 1.5vw, 2.75rem);
    font-weight: 700;
    line-height: var(--line-height-heading);
    letter-spacing: -0.02em;
    color: var(--fg-primary);
    margin-bottom: var(--space-3);
  }

  .content-description {
    font-size: 1.125rem;
    color: var(--fg-secondary);
    line-height: var(--line-height-body);
    max-width: 40rem;
  }

  /* Prose styles for slotted content */
  .content-body {
    font-size: 1rem;
    color: var(--fg-secondary);
    line-height: var(--line-height-body);
  }

  .content-body :global(h2) {
    font-size: clamp(1.375rem, 1.2rem + 0.7vw, 1.75rem);
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--fg-primary);
    margin-top: var(--space-7);
    margin-bottom: var(--space-4);
  }

  .content-body :global(h3) {
    font-size: clamp(1.125rem, 1rem + 0.5vw, 1.375rem);
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--fg-primary);
    margin-top: var(--space-6);
    margin-bottom: var(--space-3);
  }

  .content-body :global(p) {
    margin-bottom: var(--space-4);
  }

  .content-body :global(ul),
  .content-body :global(ol) {
    padding-left: var(--space-5);
    margin-bottom: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .content-body :global(ul) {
    list-style: disc;
  }

  .content-body :global(ol) {
    list-style: decimal;
  }

  .content-body :global(a) {
    color: var(--link);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color var(--transition-default);
  }

  .content-body :global(a:hover) {
    color: var(--accent);
  }

  .content-body :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: var(--bg-tertiary);
    border: 1px solid var(--border-secondary);
    border-radius: var(--radius-sm);
    padding: 0.125em 0.375em;
  }

  .content-body :global(pre) {
    background: var(--bg-secondary);
    border: 1px solid var(--border-secondary);
    border-radius: var(--radius-lg);
    padding: var(--space-4);
    overflow-x: auto;
    margin-bottom: var(--space-4);
  }

  .content-body :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    font-size: 0.8125rem;
  }

  .content-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: var(--space-4);
    font-size: 0.875rem;
  }

  .content-body :global(th),
  .content-body :global(td) {
    text-align: left;
    padding: var(--space-2) var(--space-3);
    border-bottom: 1px solid var(--border-secondary);
  }

  .content-body :global(th) {
    font-weight: 600;
    color: var(--fg-primary);
    background: var(--bg-secondary);
  }

  .content-body :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding-left: var(--space-4);
    margin-bottom: var(--space-4);
    color: var(--fg-tertiary);
    font-style: italic;
  }

  .content-body :global(hr) {
    border: none;
    border-top: 1px solid var(--border-secondary);
    margin: var(--space-6) 0;
  }

  .content-body :global(strong) {
    color: var(--fg-primary);
    font-weight: 600;
  }
</style>
