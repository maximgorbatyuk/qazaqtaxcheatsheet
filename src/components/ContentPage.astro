---
import NextPageNav from './NextPageNav.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const currentPath = Astro.url.pathname;
---

<div class="content-page-shell">
  <article class="content-page">
    <header class="content-header">
      <h1 class="content-title">{title}</h1>
      {description && <p class="content-description">{description}</p>}
    </header>

    <div class="content-body">
      <slot />
    </div>
  </article>

  <div class="content-page-nav">
    <NextPageNav currentPath={currentPath} />
  </div>
</div>

<style>
  .content-page-shell {
    --bg-secondary: #FFFFFF;
    --bg-tertiary: #EEF3F8;
    --fg-primary: #172033;
    --fg-secondary: #4B5870;
    --fg-tertiary: #6B7A8D;
    --border-primary: #D7E0EA;
    --border-secondary: #D7E0EA;
    --accent: #163E72;
    --accent-hover: #12355F;
    --link: #1B4E8A;
    --info: #1B4E8A;
    --success: #1F7A5A;
    --warning: #A66A12;
    --error: #B44343;

    width: min(var(--reading-width), calc(100% - var(--space-6)));
    margin: var(--space-6) auto;
    color: var(--fg-secondary);
  }

  .content-page {
    padding: var(--space-7) var(--space-6);
    background: #FFFFFF;
    border: 1px solid var(--border-secondary);
    border-radius: 8px;
    box-shadow: var(--shadow-md);
  }

  .content-page-nav {
    padding-inline: var(--space-6);
  }

  .content-header {
    margin-bottom: var(--space-7);
  }

  .content-title {
    font-size: clamp(1.75rem, 1.4rem + 1.5vw, 2.75rem);
    font-weight: 700;
    line-height: var(--line-height-heading);
    letter-spacing: -0.02em;
    color: var(--fg-primary);
    margin-bottom: var(--space-3);
  }

  .content-description {
    font-size: 1.125rem;
    color: var(--fg-secondary);
    line-height: var(--line-height-body);
    max-width: 40rem;
  }

  /* Prose styles for slotted content */
  .content-body {
    font-size: 1rem;
    color: var(--fg-secondary);
    line-height: var(--line-height-body);
  }

  .content-body :global(h2) {
    font-size: clamp(1.375rem, 1.2rem + 0.7vw, 1.75rem);
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--fg-primary);
    margin-bottom: var(--space-4);
  }

  .content-body :global(h3) {
    font-size: clamp(1.125rem, 1rem + 0.5vw, 1.375rem);
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--fg-primary);
    margin-bottom: var(--space-3);
  }

  .content-body :global(p) {
    margin-bottom: var(--space-4);
  }

  /* Extra spacing before headings — push from preceding element */
  .content-body :global(:has(+ h2)) {
    margin-bottom: var(--space-7);
  }

  .content-body :global(:has(+ h3)) {
    margin-bottom: var(--space-6);
  }

  .content-body :global(ul),
  .content-body :global(ol) {
    padding-left: var(--space-5);
    margin-bottom: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .content-body :global(ul) {
    list-style: disc;
  }

  .content-body :global(ol) {
    list-style: decimal;
  }

  .content-body :global(a) {
    color: var(--link);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color var(--transition-default);
  }

  .content-body :global(a:hover) {
    color: var(--accent);
  }

  .content-body :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: var(--bg-tertiary);
    border: 1px solid var(--border-secondary);
    border-radius: var(--radius-sm);
    padding: 0.125em 0.375em;
  }

  .content-body :global(pre) {
    background: var(--bg-secondary);
    border: 1px solid var(--border-secondary);
    border-radius: var(--radius-lg);
    padding: var(--space-4);
    overflow-x: auto;
    margin-bottom: var(--space-4);
  }

  .content-body :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    font-size: 0.8125rem;
  }

  .content-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: var(--space-4);
    font-size: 0.875rem;
  }

  .content-body :global(th),
  .content-body :global(td) {
    text-align: left;
    padding: var(--space-2) var(--space-3);
    border-bottom: 1px solid var(--border-secondary);
  }

  .content-body :global(th) {
    font-weight: 600;
    color: var(--fg-primary);
    background: var(--bg-secondary);
  }

  .content-body :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding-left: var(--space-4);
    margin-bottom: var(--space-4);
    color: var(--fg-tertiary);
    font-style: italic;
  }

  .content-body :global(hr) {
    border: none;
    border-top: 1px solid var(--border-secondary);
    margin: var(--space-6) 0;
  }

  .content-body :global(strong) {
    color: var(--fg-primary);
    font-weight: 600;
  }

  @media (max-width: 640px) {
    .content-page-shell {
      width: calc(100% - var(--space-3));
      margin: var(--space-2) auto var(--space-4);
    }

    .content-page {
      padding: var(--space-5) var(--space-4);
    }

    .content-page-nav {
      padding-inline: var(--space-4);
    }
  }
</style>
