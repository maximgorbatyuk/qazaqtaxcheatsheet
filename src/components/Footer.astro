---
const asciiLogo = `  ___ _____
 / _ \\_   _|
| | | || |
| |_| || |
 \\__\\_\\|_|`;
---

<footer class="footer">
  <div class="footer-grid">
    <div class="footer-col footer-brand">
      <div class="footer-logo">
        <pre class="footer-ascii" aria-hidden="true" set:html={asciiLogo} />
        <span class="footer-domain">.fyi</span>
      </div>
      <p class="footer-tagline">QazaqTaxCheatsheet</p>
      <p class="footer-copyright">Made with <span class="heart">♥</span>, Claude, and plenty of coffee breaks by <a href="https://mgorbatyuk.dev" target="_blank" rel="noopener noreferrer" class="author-link">Maxim Gorbatyuk</a></p>
    </div>

    <div class="footer-col">
      <h3 class="footer-heading">Навигация</h3>
      <ul class="footer-links">
        <li><a href="/">Главная</a></li>
        <li><a href="/taxes/">Налоги</a></li>
        <li><a href="/registration/">Регистрация</a></li>
        <li><a href="/faq/">FAQ</a></li>
        <li><a href="/banks/">Банки</a></li>
        <li><a href="/useful-for-devs/">Полезное</a></li>
        <li><a href="/archive/">Архив</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h3 class="footer-heading">Наши проекты</h3>
      <ul class="footer-links">
        <li><a href="https://techinterview.space/" target="_blank" rel="noopener noreferrer">Techinterview.space</a></li>
        <li><a href="https://claude-community.kz/" target="_blank" rel="noopener noreferrer">Claude Community KZ</a></li>
        <li><a href="https://markdownreader.org" target="_blank" rel="noopener noreferrer">Markdown Reader</a></li>
        <li><a href="https://repolyze.app" target="_blank" rel="noopener noreferrer">Repolyze.app</a></li>
        <li><a href="https://databasecli.app" target="_blank" rel="noopener noreferrer">Databasecli.app</a></li>
        <li><a href="https://evchargetracker.app" target="_blank" rel="noopener noreferrer">EV Charge Tracker (iOS)</a></li>
        <li><a href="https://mgorbatyuk.dev/journey-wallet/" target="_blank" rel="noopener noreferrer">Journey Wallet (iOS)</a></li>
        <li><a href="https://mgorbatyuk.dev/creativity-hub/" target="_blank" rel="noopener noreferrer">Creativity Hub (iOS)</a></li>
        <li><a href="https://mgorbatyuk.dev/slothy-terminal/" target="_blank" rel="noopener noreferrer">Slothy Terminal (macos)</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h3 class="footer-heading">GitHub</h3>
      <ul class="footer-links">
        <li><a href="https://github.com/maximgorbatyuk/qazaqtaxcheatsheet" target="_blank" rel="noopener noreferrer">Repository</a></li>
        <li><a href="https://github.com/maximgorbatyuk/qazaqtaxcheatsheet/issues" target="_blank" rel="noopener noreferrer">Issues</a></li>
        <li><a href="/privacy-policy/">Privacy Policy</a></li>
        <li><a href="https://github.com/maximgorbatyuk/qazaqtaxcheatsheet/blob/main/LICENSE" target="_blank" rel="noopener noreferrer">License</a></li>
      </ul>
    </div>
  </div>
</footer>

<style is:global>
  .footer {
    width: 100%;
    z-index: 1;
    background: #0E1623;
    border-top: 1px solid #1B2940;
    padding: var(--space-7) var(--space-6);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: var(--space-6);
    max-width: 64rem;
    margin: 0 auto;
  }

  .footer-logo {
    display: flex;
    align-items: flex-end;
    gap: 0.25rem;
  }

  .footer-ascii {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    line-height: 1.2;
    color: #4D79C7;
    white-space: pre;
    overflow: hidden;
    margin: 0;
  }

  .footer-domain {
    font-size: 1.5rem;
    font-weight: 700;
    color: #7A8DA3;
    line-height: 1;
    padding-bottom: 0.125rem;
  }

  .footer-tagline {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 1.1rem + 0.65vw, 1.75rem);
    color: #EAF0F8;
    margin-top: var(--space-2);
  }

  .footer-copyright {
    font-size: clamp(0.75rem, 0.7rem + 0.2vw, 0.875rem);
    color: #7A8DA3;
    margin-top: var(--space-2);
  }

  .heart {
    color: #FFD700;
  }

  .author-link {
    color: #A9B7CB;
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color var(--transition-default);
  }

  .author-link:hover {
    color: #7EAAFF;
  }

  .footer-heading {
    font-size: 0.75rem;
    font-weight: 600;
    color: #EAF0F8;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-3);
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .footer-links a {
    font-size: 0.875rem;
    color: #A9B7CB;
    text-decoration: none;
    transition: color var(--transition-default);
  }

  .footer-links a:hover {
    color: #7EAAFF;
  }

  @media (max-width: 480px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }

    .footer-logo {
      display: none;
    }
  }
</style>
