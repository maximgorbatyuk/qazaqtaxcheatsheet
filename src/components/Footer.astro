---
const asciiLogo = ` _____
|_   _|_ ___  __
  | |/ _\` \\ \\/ /
  | | (_| |>  <
  |_|\\__,_/_/\\_\\`;
---

<footer class="footer">
  <div class="footer-grid">
    <div class="footer-col footer-brand">
      <pre class="footer-ascii" aria-hidden="true" set:html={asciiLogo} />
      <p class="footer-tagline">Qazaq Tax Cheatsheet</p>
      <p class="footer-copyright">2026 Maxim Gorbatyuk. MIT License.</p>
    </div>

    <div class="footer-col">
      <h3 class="footer-heading">Навигация</h3>
      <ul class="footer-links">
        <li><a href="/">Главная</a></li>
        <li><a href="/taxes/">Налоги</a></li>
        <li><a href="/registration/">Регистрация</a></li>
        <li><a href="/faq/">FAQ</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h3 class="footer-heading">Ресурсы</h3>
      <ul class="footer-links">
        <li><a href="/banks/">Банки</a></li>
        <li><a href="/links/">Ссылки</a></li>
        <li><a href="https://maximgorbatyuk.notion.site/ip-kazakhstan-tutorial" target="_blank" rel="noopener noreferrer">Notion-версия</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h3 class="footer-heading">GitHub</h3>
      <ul class="footer-links">
        <li><a href="https://github.com/maximgorbatyuk/qazaqtaxcheatsheet" target="_blank" rel="noopener noreferrer">Репозиторий</a></li>
        <li><a href="https://github.com/maximgorbatyuk/qazaqtaxcheatsheet/issues" target="_blank" rel="noopener noreferrer">Issues</a></li>
      </ul>
    </div>
  </div>
</footer>

<style is:global>
  .footer {
    width: 100%;
    z-index: 1;
    background: #131313;
    border-top: 1px solid #525252;
    padding: var(--space-7) var(--space-6);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: var(--space-6);
    max-width: 64rem;
    margin: 0 auto;
  }

  .footer-ascii {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    line-height: 1.2;
    color: var(--accent);
    white-space: pre;
    overflow: hidden;
    margin: 0;
  }

  .footer-tagline {
    font-family: var(--font-serif);
    font-size: clamp(1.25rem, 1.1rem + 0.65vw, 1.75rem);
    color: #f5f5f5;
    margin-top: var(--space-2);
  }

  .footer-copyright {
    font-size: clamp(0.75rem, 0.7rem + 0.2vw, 0.875rem);
    color: #737373;
    margin-top: var(--space-2);
  }

  .footer-heading {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    color: #f5f5f5;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-3);
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .footer-links a {
    font-size: 0.875rem;
    color: #9a9a9a;
    text-decoration: none;
    transition: color var(--transition-default);
  }

  .footer-links a:hover {
    color: var(--accent);
  }

  @media (max-width: 480px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }

    .footer-ascii {
      display: none;
    }
  }
</style>
