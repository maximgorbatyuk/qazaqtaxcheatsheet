---
import ContentPage from './ContentPage.astro';

const links = [
  { url: 'https://mybuh.kz', name: 'mybuh.kz', description: 'Калькулятор налогов ИП на упрощенке' },
  { url: 'https://egov.kz', name: 'egov.kz', description: 'Оплата налогов, проверка задолженностей, госуслуги' },
  { url: 'https://cabinet.kgd.gov.kz', name: 'cabinet.kgd.gov.kz', description: 'Кабинет налогоплательщика: начисления, задолженности, история' },
  { url: 'https://cabinet.salyk.kz', name: 'cabinet.salyk.kz', description: 'Подача формы 910 и других форм налоговой отчетности' },
  { url: 'https://uchet.kz', name: 'uchet.kz', description: 'Курсы валют Национального банка РК' },
  { url: 'https://esf.gov.kz', name: 'esf.gov.kz', description: 'Портал электронных счетов-фактур (ЭСФ)' },
  { url: 'https://kompra.kz', name: 'kompra.kz', description: 'Проверка ИП и компаний, контрагентов, судебных дел' },
];
---

<ContentPage title="Полезное для разработчиков">
  <p class="intro">
    Подборка ссылок, сервисов и инструментов для ведения ИП на упрощенке.
  </p>

  <h2>Полезные сервисы</h2>
  <div class="table-scroll">
    <table class="data-table">
      <thead>
        <tr>
          <th>Ссылка</th>
          <th>Описание</th>
        </tr>
      </thead>
      <tbody>
        {links.map((link) => (
          <tr>
            <td><a href={link.url} target="_blank" rel="noopener noreferrer" class="link">{link.name}</a></td>
            <td>{link.description}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <h2>Как получить подтверждение аккаунта Google Developer</h2>
  <p>По ссылке ниже собраны сообщения из чата Android-разработчиков, которые рассказывают,
  как им удалось подтвердить свою личность для аккаунта Google Developer.</p>
  <p><a href="https://telegra.ph/Podtverzhdenie-akkaunt-Google-developer-07-28-2" target="_blank" rel="noopener noreferrer" class="link">telegra.ph — Подтверждение аккаунта Google Developer</a></p>
</ContentPage>
