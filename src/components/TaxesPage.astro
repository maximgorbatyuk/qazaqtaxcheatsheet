---
import ContentPage from './ContentPage.astro';
import taxesData from '../data/taxes-2026.json';
import salaryExamples from '../data/salary-examples.json';

const paymentLabels: Record<string, string> = {
  opv: 'Пенсионные отчисления (ОПВ)',
  so: 'Социальные отчисления (СО)',
  osms: 'ОСМС',
  opvr: 'ОПВР',
  ipn: 'Подоходный налог (ИПН)',
};

const formulaLabels: Record<string, string> = {
  salary: '10% от зарплаты',
  'salary_so': '5% от зарплаты',
  '1.4 * MZP': '5% от 1.4 * МЗП',
  'salary_opvr': '1.5% от зарплаты',
  income: '4% от дохода',
};

function getFormula(p: typeof taxesData.payments[number]): string {
  if (p.id === 'opv') return `${p.rate * 100}% от зарплаты`;
  if (p.id === 'so') return `${p.rate * 100}% от зарплаты`;
  if (p.id === 'osms') return `${p.rate * 100}% от 1.4 * МЗП`;
  if (p.id === 'opvr') return `${p.rate * 100}% от зарплаты`;
  if (p.id === 'ipn') return `${p.rate * 100}% от дохода`;
  return `${p.rate * 100}%`;
}
---

<ContentPage title="Какие налоги оплачивать">
  <p class="note">
    МЗП на {taxesData.year} год: <strong>{taxesData.mzp.toLocaleString('ru-RU')} тг</strong>.
    МРП на {taxesData.year} год: <strong>{taxesData.mrp.toLocaleString('ru-RU')} тг</strong>.
  </p>

  <section class="section">
    <h2 class="section-heading">Таблица обязательных платежей</h2>
    <div class="table-scroll">
      <table class="data-table">
        <thead>
          <tr>
            <th>#</th>
            <th>Платеж</th>
            <th>Сумма / Формула</th>
            <th>{taxesData.year} (мин.)</th>
            <th>Примечание</th>
          </tr>
        </thead>
        <tbody>
          {taxesData.payments.map((p, i) => (
            <tr>
              <td class="cell-center">{i + 1}</td>
              <td>{paymentLabels[p.id] ?? p.id}</td>
              <td class="cell-mono">{getFormula(p)}</td>
              <td class="cell-mono">{p.min2026 ? `${p.min2026.toLocaleString('ru-RU')} тг` : '—'}</td>
              <td class="cell-small">{p.note}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <section class="callout callout-warning">
    <p>
      <strong>Зарплата директора.</strong> ИПшник сам устанавливает себе зарплату, от которой считаются ОПВ, СО, ОПВР.
      Минимальная зарплата — 1 МЗП ({taxesData.mzp.toLocaleString('ru-RU')} тг). Если нет оборотов, ОПВ и СО можно не оплачивать,
      но ОСМС обязателен всегда.
    </p>
  </section>

  <section class="section">
    <h2 class="section-heading">Когда оплачивать?</h2>
    <div class="payment-schedule">
      <div class="schedule-item">
        <h3 class="schedule-label">Ежемесячно (до 25 числа следующего месяца)</h3>
        <ol class="schedule-list">
          <li>ОПВ (КНП 010)</li>
          <li>СО (КНП 012)</li>
          <li>ОСМС (КНП 122)</li>
          <li>ОПВР (КНП 089)</li>
        </ol>
      </div>
      <div class="schedule-item">
        <h3 class="schedule-label">Раз в полгода</h3>
        <ol class="schedule-list">
          <li>Подоходный налог (ИПН) — 4% от дохода (КНП 911). Оплачивается после подачи формы 910.</li>
        </ol>
      </div>
    </div>
  </section>

  <section class="section">
    <h2 class="section-heading">Какой доход декларировать?</h2>
    <p class="prose">
      Декларируется весь доход, полученный за полугодие, в тенге. Если вы получаете оплату в валюте,
      то конвертируйте по курсу Национального банка на день получения.
      Курсы валют можно посмотреть на <a href="https://uchet.kz" target="_blank" rel="noopener noreferrer" class="link">uchet.kz</a>.
    </p>
  </section>

  <section class="section">
    <h2 class="section-heading">Пример расчета при зарплате 600 000 тг</h2>
    <div class="table-scroll">
      <table class="data-table">
        <thead>
          <tr>
            <th>#</th>
            <th>Платеж</th>
            <th>2025</th>
            <th>2026</th>
          </tr>
        </thead>
        <tbody>
          {salaryExamples.map((row, i) => (
            <tr>
              <td class="cell-center">{i + 1}</td>
              <td>{row.label}</td>
              <td class="cell-mono">{row.amount2025.toLocaleString('ru-RU')} тг</td>
              <td class="cell-mono">{row.amount2026.toLocaleString('ru-RU')} тг</td>
            </tr>
          ))}
          <tr class="row-total">
            <td class="cell-center"></td>
            <td><strong>Итого ежемесячно</strong></td>
            <td class="cell-mono"><strong>{salaryExamples.reduce((s, r) => s + r.amount2025, 0).toLocaleString('ru-RU')} тг</strong></td>
            <td class="cell-mono"><strong>{salaryExamples.reduce((s, r) => s + r.amount2026, 0).toLocaleString('ru-RU')} тг</strong></td>
          </tr>
        </tbody>
      </table>
    </div>
    <p class="note">
      Пример для зарплаты 600 000 тг. ИПН считается отдельно по итогам полугодия от дохода.
    </p>
  </section>
</ContentPage>

<style>
  .note {
    font-size: 1rem;
    color: var(--fg-secondary);
    line-height: var(--line-height-body);
    margin-bottom: var(--space-5);
  }

  .section {
    margin-bottom: var(--space-7);
  }

  .section-heading {
    font-size: clamp(1.25rem, 1.1rem + 0.6vw, 1.5rem);
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--fg-primary);
    margin-bottom: var(--space-4);
  }

  .table-scroll {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    margin-bottom: var(--space-4);
    border: 1px solid var(--border-secondary);
    border-radius: var(--radius-lg);
  }

  .data-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9375rem;
    white-space: nowrap;
  }

  .data-table th {
    text-align: left;
    padding: var(--space-3) var(--space-4);
    background: var(--bg-tertiary);
    color: var(--fg-secondary);
    font-weight: 600;
    font-size: 0.8125rem;

    text-transform: uppercase;
    letter-spacing: 0.03em;
    border-bottom: 1px solid var(--border-secondary);
  }

  .data-table td {
    padding: var(--space-3) var(--space-4);
    color: var(--fg-primary);
    border-bottom: 1px solid var(--border-secondary);
  }

  .data-table tbody tr:last-child td {
    border-bottom: none;
  }

  .data-table tbody tr:hover {
    background: var(--bg-secondary);
  }

  .cell-center {
    text-align: center;
    color: var(--fg-tertiary);
  }

  .cell-mono {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
  }

  .cell-small {
    white-space: normal;
    max-width: 18rem;
    font-size: 0.875rem;
    color: var(--fg-secondary);
  }

  .row-total {
    background: var(--bg-tertiary);
  }

  .row-total td {
    border-bottom: none;
  }

  .callout {
    padding: var(--space-5);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-secondary);
    margin-bottom: var(--space-6);
  }

  .callout-info {
    border-left: 4px solid var(--info);
    background: color-mix(in srgb, var(--info) 5%, var(--bg-secondary));
  }

  .callout p {
    font-size: 1rem;
    color: var(--fg-secondary);
    line-height: var(--line-height-body);
  }

  .payment-schedule {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .schedule-item {
    padding: var(--space-5);
    border: 1px solid var(--border-secondary);
    border-radius: var(--radius-lg);
    background: var(--bg-secondary);
  }

  .schedule-label {
    font-weight: 600;
    font-size: 1rem;
    color: var(--fg-primary);
    margin-bottom: var(--space-3);
  }

  .schedule-list {
    padding-left: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    font-size: 1rem;
    color: var(--fg-secondary);
    line-height: var(--line-height-body);
  }

  .prose {
    font-size: 1rem;
    color: var(--fg-secondary);
    line-height: var(--line-height-body);
    margin-bottom: var(--space-3);
  }

  .link {
    color: var(--link);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .link:hover {
    text-decoration-thickness: 2px;
  }
</style>
