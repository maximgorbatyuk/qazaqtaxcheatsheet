---
import ContentPage from './ContentPage.astro';
---

<ContentPage title="Как получить УНК">
  <div class="stub">
    <div class="stub-icon" aria-hidden="true">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
        <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
      </svg>
    </div>
    <p class="stub-text">
      УНК (учетный номер контракта) — это номер, который присваивается вашему валютному контракту в банке.
      Здесь будет подробная инструкция по получению УНК: какие документы нужны, куда обращаться,
      сроки оформления и частые вопросы.
    </p>
    <p class="stub-note">Контент скоро появится.</p>
  </div>
</ContentPage>

<style>
  .stub {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: var(--space-8) var(--space-4);
    gap: var(--space-4);
  }

  .stub-icon {
    color: var(--fg-tertiary);
    opacity: 0.5;
  }

  .stub-text {
    font-size: 1rem;
    color: var(--fg-secondary);
    line-height: var(--line-height-body);
    max-width: 36rem;
  }

  .stub-note {
    font-size: 0.875rem;
    color: var(--fg-tertiary);
    font-style: italic;
  }
</style>
